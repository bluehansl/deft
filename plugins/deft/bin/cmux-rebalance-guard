#!/usr/bin/env bash
# cmux-rebalance-guard — 워커 spawn 과정 동안 Lead pane 비율이 틀어지는 순간을 감지해 즉시 rebalancing.
#
# 배경(실측): claude Agent tool 워커는 spawn ~1.4초 후 cmux 가 레이아웃을 재계산하며 Lead pane 을 깎는다
#   (예: 2컬럼 60% → 26%). cmux 재계산 자체는 외부에서 못 막으므로, "틀어짐 감지 → 즉시 교정" 워치독으로
#   사용자 체감 깜빡임을 최소화한다. cmux-rebalancing 자체가 ~3.6초(resize settle) 걸려 깜빡임의 주원인이라,
#   폴링을 빠르게(0.1초) 해 틀어진 직후 교정을 시작하고, 마지막 spawn 후 grace-sec 동안 추가 감시해
#   늦게 오는 재계산까지 잡은 뒤 자동 종료한다.
#
# cmux-rebalance-watch 와의 차이: watch 는 "pane 수 settle 후 1회" rebalance(첫 배치용). guard 는
#   "매 틀어짐마다 교정 + grace 종료"(spawn 중 반복 재계산 대응 — claude Agent 혼합 구성에 필수).
#
# 사용: cmux-rebalance-guard <workspace-ref> [max-sec] [poll-sec] [lead-min-pct] [grace-sec] [done-flag] [expected-panes]
#   <workspace-ref>  대상 워크스페이스 (예: workspace:5)
#   [max-sec]        총 가동 시간 상한(기본 90초 — 신호 누락 시 잔존 방지 안전망)
#   [poll-sec]       폴링 간격(기본 0.1 — 틀어진 직후 즉시 감지)
#   [lead-min-pct]   Lead 폭이 이 % 미만이면 틀어짐 판정(기본 50 — 2컬럼 목표 60%, 여유 둠)
#   [grace-sec]      종료 전 마지막 안정 확인 윈도(기본 5초). 이 동안 무틀어짐이면 종료.
#   [done-flag]      (선택) Lead 의 "모든 spawn 완료" 신호 파일 경로. **설정 시: 이 파일이 생기기 전엔
#                    grace 무틀어짐이어도 종료하지 않고 계속 비율을 지킨다**(spawn 기간 동안 절대 안 죽음).
#                    파일이 touch 되면 그때부터 grace 무틀어짐 확인 후 종료 → spawn 이 얼마나 걸리든
#                    (느린 4번째 워커 재계산 포함) 끝까지 커버. 미설정 시 종전대로 "마지막 안정 후 grace 종료"(하위호환).
#   [expected-panes] (선택) Lead 가 spawn 대상 팀원 수 확정 시 넘기는 **예정 총 pane 수**(Lead 포함 = 워커 수 + 1).
#                    **≥3 이면**(최종 3컬럼+ 또는 다행 예정) 현재 pane 이 2개(Lead+워커1)일 때도 교정 임계를 58 로 올려,
#                    cmux 기본 2-pane 분할(50:50)을 **워커가 다 뜨기 전부터 미리 목표 60:40 으로** 당긴다.
#                    ≤2(또는 미지정)면 최종 2-pane=50:50 이 기본 분할이라 별도 교정 불요 → 기존 임계(50)대로.
#
# 통합 사용(권장 — done-flag + expected-panes): Lead 가 워커 spawn 시작 직전 백그라운드로 발사 →
#   FLAG="$TEAM_DIR/.spawn-done"; rm -f "$FLAG"
#   EXP=$((WORKER_COUNT + 1))   # Lead 포함 예정 총 pane
#   nohup cmux-rebalance-guard "$LEAD_WORKSPACE" 90 0.1 50 5 "$FLAG" "$EXP" >/dev/null 2>&1 &
#   ... 워커를 차례로 spawn ... → 마지막 워커 spawn 반환 후:  touch "$FLAG"
#   → guard 는 spawn 진행 중엔 시간 무관하게 비율을 지키고(예정 3+면 첫 워커부터 60:40), 플래그 후 마지막 재계산까지 잡고 종료.
#
# 출력: 감지·교정 이벤트만 한 줄씩(조용한 동안은 무출력)
set -u
WS="${1:?usage: cmux-rebalance-guard <workspace-ref> [max-sec] [poll-sec] [lead-min-pct] [grace-sec] [done-flag]}"
MAXSEC="${2:-90}"
POLL="${3:-0.1}"
MINPCT="${4:-50}"
GRACE="${5:-5}"
DONE_FLAG="${6:-}"
EXPECTED_PANES="${7:-0}"   # Lead 가 spawn 대상 팀원 수 확정 시 직접 넘기는 "예정 총 pane 수"(Lead 포함 = 워커 수 + 1).
                          #   0=미지정(기존 동작). **≥3 이면** 현재 pane 이 2개(Lead+워커1)일 때도 교정 허용
                          #   — 최종 다(多)컬럼 목표 비율(2컬럼 60:40 등)을 워커가 다 뜨기 전부터 미리 맞춘다.
                          #   ≤2 면 최종 2-pane=50:50 이 cmux 기본 분할이라 별도 교정 불요 → 기존대로 NP<2 skip.
command -v cmux >/dev/null 2>&1 || { echo "ERROR: cmux 없음" >&2; exit 1; }
command -v cmux-rebalancing >/dev/null 2>&1 || { echo "ERROR: cmux-rebalancing 없음" >&2; exit 1; }
command -v jq >/dev/null 2>&1 || { echo "ERROR: jq 없음" >&2; exit 1; }
ITERS=$(awk "BEGIN{print int($MAXSEC/$POLL)}")
GRACE_ITERS=$(awk "BEGIN{print int($GRACE/$POLL)}")
DEBOUNCE=0   # rebalancing 후 잠깐 감지 멈춤(settle + 깜빡임 방지)
STABLE=0     # 마지막 교정/안정 이후 무틀어짐 연속 폴 수 — GRACE_ITERS 도달 시 조기 종료
for i in $(seq 1 "$ITERS"); do
  if [ "$DEBOUNCE" -gt 0 ]; then DEBOUNCE=$((DEBOUNCE-1)); sleep "$POLL"; continue; fi
  # Lead(첫 컬럼, 최소 x) 폭 / 컨테이너 폭 비율
  J=$(cmux list-panes --workspace "$WS" --json 2>/dev/null)
  [ -z "$J" ] && { sleep "$POLL"; continue; }
  PCT=$(printf '%s' "$J" | jq -r '
    (.container_frame.width) as $cw
    | ([.panes[]|{x:.pixel_frame.x,w:.pixel_frame.width}]|sort_by(.x)|first) as $lead
    | if $cw>0 and $lead then (($lead.w/$cw)*100|floor) else -1 end' 2>/dev/null)
  NP=$(printf '%s' "$J" | jq -r '.panes|length' 2>/dev/null)
  # 워커가 1명 이상(Lead 외 pane ≥1, 즉 NP≥2) 이어야 교정 의미 — Lead 단독(NP<2)은 나눌 pane 이 없어 skip
  #   + 안정 카운트 리셋(워커 0이면 grace 종료 안 함 — 워커 뜨기 전 조기 종료 방지).
  if [ "${NP:-1}" -lt 2 ]; then STABLE=0; sleep "$POLL"; continue; fi
  # 발동 임계(EFF_MIN): 기본은 MINPCT(50). 단 **EXPECTED_PANES≥3**(최종 다컬럼 예정)이고 아직 **현재 NP=2**(워커1만)면,
  #   cmux 기본 2-pane 분할은 50:50 이라 MINPCT=50 임계엔 안 걸려 60:40 으로 당겨지지 않는다(실측 — 워커2 가 와야 깎임).
  #   → 이 구간만 임계를 58 로 올려 "50:50 → 목표 60:40" 을 워커가 다 뜨기 전 **미리** 맞춘다.
  #   (58: 목표 Lead 60% 보다 약간 낮춰 60:40 정상 상태를 다시 안 건드리게 — 깜빡임 방지.)
  EFF_MIN="$MINPCT"
  if [ "${EXPECTED_PANES:-0}" -ge 3 ] && [ "${NP:-0}" -eq 2 ]; then EFF_MIN=58; fi
  if [ "${PCT:-100}" -ge 0 ] && [ "${PCT:-100}" -lt "$EFF_MIN" ] 2>/dev/null; then
    echo "$(date '+%H:%M:%S') GUARD: Lead ${PCT}% (<${EFF_MIN}%, expected=${EXPECTED_PANES} np=${NP}) — 틀어짐 감지 → rebalancing"
    cmux-rebalancing >/dev/null 2>&1   # 동기 호출(~3.6s) — 반환 시 이미 settle
    LP=$(printf '%s' "$J" | jq -r '[.panes[]|{x:.pixel_frame.x,r:.ref}]|sort_by(.x)|first.r')
    cmux focus-pane --pane "$LP" --workspace "$WS" >/dev/null 2>&1
    STABLE=0          # 틀어짐 발생 → 안정 카운트 리셋
    DEBOUNCE=$(awk "BEGIN{print int(0.5/$POLL)}")   # rebalancing 직후 0.5초만 디바운스(이미 settle됨)
  else
    STABLE=$((STABLE+1))
    # 종료 판정: grace-sec 동안 무틀어짐일 때.
    #   - done-flag 설정 시: 플래그 파일이 **생긴 뒤에만** 종료 허용 → spawn 진행 중(플래그 전)엔
    #     시간 무관하게 비율을 계속 지킨다(느린 마지막 워커 재계산까지 커버).
    #   - done-flag 미설정 시: 종전대로 마지막 안정 후 grace 종료(하위호환).
    if [ "$STABLE" -ge "$GRACE_ITERS" ]; then
      if [ -z "$DONE_FLAG" ] || [ -f "$DONE_FLAG" ]; then
        REASON=$([ -n "$DONE_FLAG" ] && echo "spawn 완료 플래그 + ${GRACE}s 무틀어짐" || echo "마지막 안정 후 ${GRACE}s 무틀어짐")
        echo "$(date '+%H:%M:%S') cmux-rebalance-guard 안정 종료 ($REASON — Lead ${PCT}%)"
        exit 0
      fi
      # done-flag 설정됐는데 아직 플래그 없음 → 종료 안 함(STABLE 은 유지해 플래그 즉시 종료 가능). 비율 감시 계속.
    fi
  fi
  sleep "$POLL"
done
echo "$(date '+%H:%M:%S') cmux-rebalance-guard 종료 (max-sec 도달)"
