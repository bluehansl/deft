#!/usr/bin/env bash
# deft-claude-native-spawn — claudex(Lead) 팀에 **claude 를 네이티브 팀원으로** 붙인다.
#
# `deft-claudex-native-spawn` 의 **역방향**. Lead=claudex MVP 용:
#   claudex 가 Lead(`--claude-team <id> --claude-team-agent team-lead`)로 떠서 자기 team inbox 를 watch 할 때,
#   이 헬퍼로 claude 팀원을 pane 에 기동하면 — **cmux / Orca 양쪽 지원** (ORCA_* 존재 시 orca 모드
#   자동 분기: orca terminal split --command) — claudex Lead 는 평범한 send_message(to:"<name>") 로
#   claude 팀원과 네이티브 통신한다. (claude 팀원 spawn 플래그는 claude-mate-a 프로세스 실측.)
#
# 전제: Lead=claudex 팀이 이미 materialize 됨(team dir + config.json 존재, leadSessionId 포함).
#   팀 materialize + claudex-Lead 기동은 별도(deft-claudex-lead 셋업 / 수동). 이 헬퍼는 claude 워커 추가만.
#
# 사용: deft-claude-native-spawn <team-id> <worker-name> [cwd] [model]
#   <team-id>      session-<short> (claudex-Lead 가 바인딩한 팀)
#   <worker-name>  claude 팀원 이름 (claudex Lead 가 send_message(to:...) 로 부를 이름)
#   [cwd]          claude 워커 cwd (기본 $PWD)
#   [model]        claude 모델 (기본 fable)
#
# 환경: CLAUDE_NATIVE_BIN(claude 경로 override, 기본 PATH claude) / CLAUDE_CONFIG_DIR(기본 ~/.claude)
#   DEFT_LEAD_SESSION  --parent-session-id 오버라이드. Lead=Claude(회의/작업 모드)면 실제 Lead 세션
#                      ($CLAUDE_CODE_SESSION_ID)을 줘야 onboarding 회피. 미설정 시 config leadSessionId(Lead=claudex 케이스).
#   DEFT_BUS_DIR       (회의 모드) board 버스 세션 dir. 설정 시 --mcp-config bus 주입(팀+버스 공존). 미설정=순수 NTP.
#   DEFT_BUS_BIN       multi-round-bus 경로 오버라이드(미설정 시 PATH).
#   DEFT_BASE_WORKSPACE  (cmux 모드 전용) pane 분할 대상 워크스페이스(예: workspace:10). cmux new-split 은
#                      --surface 단독을 해석 못 한다(window 컨텍스트 필요) → 비대화형 Bash·resume 후 caller
#                      stale 환경에선 반드시 --workspace 로 분할해야 한다(실측: --surface 는 not_found).
#                      미설정 시 cmux identify 의 caller→focused workspace_ref 폴백. orca 모드는 불요.
#   DEFT_TUI_WAIT_MS   (orca 모드) tui-idle 대기 timeout ms (기본 90000).
# 출력: JSON 한 줄 — cmux: {spawned,team,surface,worker,leadSessionId,registered}
#                  orca: {spawned,team,env:"orca",terminal,surface:"",worker,leadSessionId,registered}
set -u

TEAM_ID="${1:?usage: deft-claude-native-spawn <team-id> <worker-name> [cwd] [model]}"
WORKER="${2:?worker-name required}"
CWD="${3:-$PWD}"
MODEL="${4:-fable}"

CLAUDE_BIN="${CLAUDE_NATIVE_BIN:-$(command -v claude 2>/dev/null || true)}"
if [ -z "$CLAUDE_BIN" ] || [ ! -x "$CLAUDE_BIN" ]; then
  echo "ERROR: claude 바이너리 없음. CLAUDE_NATIVE_BIN 으로 경로 지정." >&2; exit 1
fi
CLAUDE_HOME="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
TEAM_DIR="$CLAUDE_HOME/teams/$TEAM_ID"
CFG="$TEAM_DIR/config.json"
if [ ! -f "$CFG" ]; then
  echo "ERROR: 팀 config 없음($CFG). claudex-Lead 팀이 먼저 materialize 돼야 한다." >&2; exit 1
fi
command -v jq >/dev/null 2>&1 || { echo "ERROR: jq 필요" >&2; exit 1; }
# Lead=Claude 면 DEFT_LEAD_SESSION($CLAUDE_CODE_SESSION_ID)을 줘야 onboarding 회피 — config leadSessionId 는
# 팀 자체 id 라 claude 가 parent 를 못 찾아 OAuth onboarding 에 갇힌다(실측 함정). Lead=claudex 면 폴백.
LEAD_SESSION="${DEFT_LEAD_SESSION:-$(jq -r '.leadSessionId // empty' "$CFG")}"
[ -n "$LEAD_SESSION" ] || { echo "ERROR: parent-session 없음 (DEFT_LEAD_SESSION 또는 config leadSessionId)" >&2; exit 1; }

# ── orca 모드 (Orca 1.4.150+ 실측) — cmux CLI 호출 전면 금지(별도 cmux 앱 오발사) → orca terminal 기동 ──
#   deft-claudex-native-spawn 의 orca 분기와 동일 구조: split --command 원샷(빈 pane send·readiness 불요),
#   anchor 는 .last-worker-terminal(직전 워커 아래 vertical) → 없으면 Lead($ORCA_TERMINAL_HANDLE) 우측 horizontal.
if [ -n "${ORCA_WORKTREE_ID:-}" ] || [ -n "${ORCA_TERMINAL_HANDLE:-}" ]; then
  command -v orca >/dev/null 2>&1 || { echo "ERROR: orca CLI 없음 — Orca 관리 터미널에서 실행하라." >&2; exit 1; }

  # 회의 모드 board 버스(선택) — cmux 경로와 동일한 --mcp-config 파일 주입
  BUS_OPT=""
  if [ -n "${DEFT_BUS_DIR:-}" ]; then
    BUS_BIN_PATH="${DEFT_BUS_BIN:-$(command -v multi-round-bus 2>/dev/null || true)}"
    if [ -n "$BUS_BIN_PATH" ]; then
      MCPCFG="$TEAM_DIR/mcp-${WORKER}.json"
      printf '{"mcpServers":{"bus":{"type":"stdio","command":"%s","args":["mcp"],"env":{"MULTI_ROUND_SESSION_DIR":"%s","BUS_PARTICIPANT":"%s"}}}}\n' "$BUS_BIN_PATH" "$DEFT_BUS_DIR" "$WORKER" > "$MCPCFG"
      BUS_OPT=" --strict-mcp-config --mcp-config '$MCPCFG' --allowedTools mcp__bus__check_messages,mcp__bus__post_message,mcp__bus__list_participants"
    else
      echo "WARN: DEFT_BUS_DIR 설정됐으나 multi-round-bus 미발견 — board 버스 없이 팀원만." >&2
    fi
  fi
  LAUNCH="cd '$CWD' && CLAUDE_CONFIG_DIR='$CLAUDE_HOME' exec '$CLAUDE_BIN' --agent-id '$WORKER@$TEAM_ID' --agent-name '$WORKER' --team-name '$TEAM_ID' --parent-session-id '$LEAD_SESSION' --agent-type claude --agent-color cyan --dangerously-skip-permissions --model '$MODEL'$BUS_OPT"

  LASTTERM_FILE="$TEAM_DIR/.last-worker-terminal"
  PREV_TERM="$(cat "$LASTTERM_FILE" 2>/dev/null)"
  ANCHOR="$PREV_TERM"; SPLIT_DIR=vertical                                     # 2번째+: 직전 워커 아래(상하)
  [ -n "$ANCHOR" ] || { ANCHOR="${ORCA_TERMINAL_HANDLE:-}"; SPLIT_DIR=horizontal; }  # 첫 워커: Lead 우측(좌우)
  SPLIT_OUT="$(orca terminal split --terminal "$ANCHOR" --direction "$SPLIT_DIR" --command "$LAUNCH" --json 2>/dev/null)"
  HANDLE="$(printf '%s' "$SPLIT_OUT" | jq -r '.result.split.handle // empty' 2>/dev/null)"
  if [ -z "$HANDLE" ] && [ -n "$PREV_TERM" ]; then
    SPLIT_OUT="$(orca terminal split --terminal "${ORCA_TERMINAL_HANDLE:-}" --direction horizontal --command "$LAUNCH" --json 2>/dev/null)"
    HANDLE="$(printf '%s' "$SPLIT_OUT" | jq -r '.result.split.handle // empty' 2>/dev/null)"
  fi
  if [ -z "$HANDLE" ]; then
    SPLIT_OUT="$(orca terminal create --worktree active --command "$LAUNCH" --json 2>/dev/null)"
    HANDLE="$(printf '%s' "$SPLIT_OUT" | jq -r '[..|.handle? // empty]|map(select(.!=""))|first // empty' 2>/dev/null)"
  fi
  [ -n "$HANDLE" ] || { echo "ERROR: orca terminal 기동 실패: $SPLIT_OUT" >&2; exit 1; }
  printf %s "$HANDLE" > "$LASTTERM_FILE"

  orca terminal wait --terminal "$HANDLE" --for tui-idle --timeout-ms "${DEFT_TUI_WAIT_MS:-90000}" --json >/dev/null 2>&1 \
    || echo "WARN: tui-idle 대기 timeout — claude 부팅 지연 가능(진행은 계속)." >&2

  # 팀 config members 등록 (idempotent, atomic — cmux 경로와 동일. tmuxPaneId 빈 값: name 라우팅)
  REGISTERED=0
  if jq -e --arg n "$WORKER" 'any(.members[]?; .name==$n)' "$CFG" >/dev/null 2>&1; then
    REGISTERED="already"
  else
    TS="$(date +%s)000"
    if jq --arg n "$WORKER" --arg tid "$TEAM_ID" --arg cwd "$CWD" --arg model "$MODEL" --argjson ts "$TS" \
        '.members += [{agentId:($n+"@"+$tid), name:$n, color:"cyan", joinedAt:$ts, tmuxPaneId:"", subscriptions:[], agentType:"claude", model:$model, prompt:"claude 네이티브 팀원(deft-claude-native-spawn/orca)", planModeRequired:false, cwd:$cwd, backendType:"tmux", isActive:true}]' \
        "$CFG" > "$CFG.deft-tmp" 2>/dev/null && mv "$CFG.deft-tmp" "$CFG"; then
      REGISTERED=1
    else
      rm -f "$CFG.deft-tmp" 2>/dev/null; echo "WARN: members 등록 실패" >&2
    fi
  fi
  # 워커 자기 inbox 보장
  [ -f "$TEAM_DIR/inboxes/$WORKER.json" ] || { mkdir -p "$TEAM_DIR/inboxes"; printf '[]' > "$TEAM_DIR/inboxes/$WORKER.json"; }

  printf '{"spawned":"%s","team":"%s","env":"orca","terminal":"%s","surface":"","worker":"%s","leadSessionId":"%s","registered":"%s"}\n' \
    "$WORKER" "$TEAM_ID" "$HANDLE" "$WORKER" "$LEAD_SESSION" "$REGISTERED"
  echo "다음: Lead 는 SendMessage/send_message(to:\"$WORKER\") 로 네이티브 통신. pane 정리: orca terminal close --terminal $HANDLE"
  exit 0
fi

# cmux 가드
if ! command -v cmux >/dev/null 2>&1 || ! cmux identify >/dev/null 2>&1; then
  echo "ERROR: cmux 환경 아님(pane 기동 불가)." >&2; exit 1
fi
LEAD_PANE="$(cmux identify 2>/dev/null | jq -r .caller.pane_ref)"

# 워커 pane 분할 — 표준 레이아웃(SKILL.md §3-A): 첫 워커는 우측 새 컬럼(right),
# 이후 워커는 직전 워커 pane 아래로 세로 스택(down) → "Lead | 워커 상하 스택" 2컬럼 유지.
# (claudex 헬퍼와 동일 — 혼합 회의에서 claude·claudex 워커가 같은 우측 컬럼에 함께 쌓이게 한다.
#  이게 없으면 claude 워커가 매번 Lead 옆 새 컬럼을 만들어 1:1:N 으로 깨진다 — 실측 버그.)
# base workspace: DEFT_BASE_WORKSPACE 우선, 없으면 caller→focused workspace_ref 폴백.
# ⚠️ cmux new-split/send/focus 는 --surface 단독 ref 를 해석 못 한다(비대화형 Bash·resume 후 caller stale
#    환경 실측: --surface 는 "not_found"/"Surface is not a terminal"). → ref 호출엔 --workspace 컨텍스트 동반.
# ⚠️ down 분할 대상 지정: --surface 가 안 되므로 "직전 워커 pane 을 focus → new-split down" 으로 우회
#    (focused pane 기준 분할). 직전 워커 pane 은 team dir 상태파일(.last-worker-pane)로 헬퍼 간 공유 —
#    NTP 헬퍼는 워커 1명씩 독립 호출이라 직전 surface 를 인자로 못 받기 때문.
BASE_WS="${DEFT_BASE_WORKSPACE:-$(cmux identify 2>/dev/null | jq -r '.caller.workspace_ref // .focused.workspace_ref // empty')}"
[ -n "$BASE_WS" ] || { echo "ERROR: 대상 워크스페이스 불명 — DEFT_BASE_WORKSPACE 로 Lead 워크스페이스(예: workspace:10)를 명시하라." >&2; exit 1; }
WS_OPT=(--workspace "$BASE_WS")
LASTPANE_FILE="$TEAM_DIR/.last-worker-pane"
PREV_PANE="$(cat "$LASTPANE_FILE" 2>/dev/null)"
if [ -n "$PREV_PANE" ] && cmux list-panes "${WS_OPT[@]}" --json 2>/dev/null | jq -e --arg p "$PREV_PANE" '.panes[]?|select(.ref==$p)' >/dev/null 2>&1; then
  # 2번째+ 워커: 직전 워커 pane 아래로 (focus → down)
  cmux focus-pane --pane "$PREV_PANE" "${WS_OPT[@]}" >/dev/null 2>&1
  SPLIT="$(cmux new-split down "${WS_OPT[@]}" --focus false 2>&1)"
else
  # 첫 워커: 우측 새 컬럼
  SPLIT="$(cmux new-split right "${WS_OPT[@]}" --focus false 2>&1)"
fi
SURF="$(printf '%s' "$SPLIT" | grep -oE 'surface:[0-9]+' | head -1)"
[ -n "$SURF" ] || { echo "ERROR: pane 분할 실패(workspace=$BASE_WS): $SPLIT" >&2; exit 1; }
# 새 워커 pane:ref 를 상태파일에 기록(다음 워커가 이 아래로 down) — surface→pane 매핑은 list-panes
NEW_PANE="$(cmux list-panes "${WS_OPT[@]}" --json 2>/dev/null | jq -r --arg s "$SURF" '.panes[]?|select(.selected_surface_ref==$s)|.ref' 2>/dev/null | head -1)"
[ -n "$NEW_PANE" ] && printf %s "$NEW_PANE" > "$LASTPANE_FILE"
command -v cmux-rebalancing >/dev/null 2>&1 && cmux-rebalancing >/dev/null 2>&1
cmux focus-pane --pane "$LEAD_PANE" "${WS_OPT[@]}" >/dev/null 2>&1

# readiness 가드 (lazy-init send 유실 방지). pane 셸 $TMUX_PANE 도 best-effort 캡처.
MARK="$TEAM_DIR/.ready-${WORKER}-$$"; PANEFILE="$TEAM_DIR/.pane-${WORKER}-$$"
mkdir -p "$TEAM_DIR" 2>/dev/null; rm -f "$MARK" "$PANEFILE"
cmux send --surface "$SURF" "${WS_OPT[@]}" "mkdir -p '$TEAM_DIR'; printf %s \"\$TMUX_PANE\" > '$PANEFILE' 2>/dev/null; touch '$MARK'"
cmux send-key --surface "$SURF" "${WS_OPT[@]}" Enter
ready=0; for _ in $(seq 1 15); do [ -f "$MARK" ] && { ready=1; break; }; sleep 1; done
PANE_ID="$(cat "$PANEFILE" 2>/dev/null)"; rm -f "$MARK" "$PANEFILE"
if [ "$ready" != "1" ]; then
  echo "BLOCKED: pane 셸 미기동(lazy-init) — cmux 워크스페이스를 전면 활성화 후 재시도." >&2; exit 2
fi

# 팀 config members 에 claude 워커 등록 (idempotent, atomic). agentType=claude.
REGISTERED=0
if jq -e --arg n "$WORKER" 'any(.members[]?; .name==$n)' "$CFG" >/dev/null 2>&1; then
  REGISTERED="already"
else
  TS="$(date +%s)000"
  if jq --arg n "$WORKER" --arg tid "$TEAM_ID" --arg pane "$PANE_ID" --arg cwd "$CWD" --arg model "$MODEL" --argjson ts "$TS" \
      '.members += [{agentId:($n+"@"+$tid), name:$n, color:"cyan", joinedAt:$ts, tmuxPaneId:$pane, subscriptions:[], agentType:"claude", model:$model, prompt:"claude 네이티브 팀원(deft-claude-native-spawn)", planModeRequired:false, cwd:$cwd, backendType:"tmux", isActive:true}]' \
      "$CFG" > "$CFG.deft-tmp" 2>/dev/null && mv "$CFG.deft-tmp" "$CFG"; then
    REGISTERED=1
  else
    rm -f "$CFG.deft-tmp" 2>/dev/null; echo "WARN: members 등록 실패" >&2
  fi
fi
# 워커 자기 inbox 보장
[ -f "$TEAM_DIR/inboxes/$WORKER.json" ] || { mkdir -p "$TEAM_DIR/inboxes"; printf '[]' > "$TEAM_DIR/inboxes/$WORKER.json"; }

# 회의 모드 board 버스(선택): DEFT_BUS_DIR 있으면 --mcp-config bus 주입 →
# claude 가 팀 멤버(NTP 깨우기·identity UI) + 버스 MCP(board) 공존. 작업 모드면 미설정 → 순수 NTP.
BUS_OPT=""
if [ -n "${DEFT_BUS_DIR:-}" ]; then
  BUS_BIN_PATH="${DEFT_BUS_BIN:-$(command -v multi-round-bus 2>/dev/null || true)}"
  if [ -n "$BUS_BIN_PATH" ]; then
    MCPCFG="$TEAM_DIR/mcp-${WORKER}.json"
    printf '{"mcpServers":{"bus":{"type":"stdio","command":"%s","args":["mcp"],"env":{"MULTI_ROUND_SESSION_DIR":"%s","BUS_PARTICIPANT":"%s"}}}}\n' "$BUS_BIN_PATH" "$DEFT_BUS_DIR" "$WORKER" > "$MCPCFG"
    # --allowedTools: board 도구 사전 허용 — --dangerously-skip-permissions 가 있어도 명시해 두면
    #   제한 모드 폴백·향후 권한 정책 변경 시에도 post_message 거부로 "수신만 되고 발신 불가" 반쪽
    #   참가자가 되는 것을 막는다(근거: RATIONALE R-10 — 옛 버스 경로 워커에 있던 가드).
    BUS_OPT=" --strict-mcp-config --mcp-config '$MCPCFG' --allowedTools mcp__bus__check_messages,mcp__bus__post_message,mcp__bus__list_participants"
  else
    echo "WARN: DEFT_BUS_DIR 설정됐으나 multi-round-bus 미발견 — board 버스 없이 팀원만." >&2
  fi
fi

# claude 팀원 기동 (관측 플래그 + 선택적 board 버스). exec 로 종료 시 pane auto-close. CLAUDE_CONFIG_DIR 전파.
LAUNCH="cd '$CWD' && CLAUDE_CONFIG_DIR='$CLAUDE_HOME' exec '$CLAUDE_BIN' --agent-id '$WORKER@$TEAM_ID' --agent-name '$WORKER' --team-name '$TEAM_ID' --parent-session-id '$LEAD_SESSION' --agent-type claude --agent-color cyan --dangerously-skip-permissions --model '$MODEL'$BUS_OPT"
cmux send --surface "$SURF" "${WS_OPT[@]}" "$LAUNCH"
cmux send-key --surface "$SURF" "${WS_OPT[@]}" Enter

printf '{"spawned":"%s","team":"%s","surface":"%s","worker":"%s","leadSessionId":"%s","registered":"%s"}\n' \
  "$WORKER" "$TEAM_ID" "$SURF" "$WORKER" "$LEAD_SESSION" "$REGISTERED"
echo "다음: claudex Lead 는 send_message(to:\"$WORKER\") 로 claude 팀원과 네이티브 통신."
