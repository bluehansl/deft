#!/usr/bin/env bash
# deft-review — multi-check 리뷰어 CLI 실행 헬퍼
#
# 목적: 리뷰어(codex/claude/gemini) 호출의 CLI 선택·실행 플래그·모델·추론수준을
#       한 곳에 캡슐화한다. 페르소나/스폰 프롬프트가 raw bash 블록을 노출하지 않고
#       `deft-review <engine>` 한 줄만 적으면 되도록 — 대화형 pane 의 구현코드 노출 제거 +
#       구현 단일 진실 소스(SSOT, deft-model 과 동일 사상).
#
# 사용:
#   deft-review codex  "<프롬프트>"        # 인자로 전달 (짧은 프롬프트)
#   printf '%s' "<프롬프트>" | deft-review codex   # stdin (긴/특수문자 프롬프트 — 권장)
#   deft-review claude  "<프롬프트>"
#   deft-review gemini  "<프롬프트>"
#
# engine 별 동작:
#   codex  : claudex 우선(없으면 codex) — `-a never exec --sandbox read-only -m gpt-5.5 -c model_reasoning_effort=xhigh`
#   claude : `claude -p ... --model $(deft-model claude||opus) --permission-mode dontAsk --output-format text`
#   gemini : `GEMINI_POLICY_ALLOW_READONLY=true gemini -p ... -m gemini-3-flash-preview --approval-mode plan -o text`
#
# 출력은 해당 CLI 출력을 그대로 stdout 으로 흘린다(요약·수정 없음). 미설치 시 <ENGINE>_NOT_INSTALLED 출력 후 exit 0.
set -euo pipefail

ENGINE="${1:-}"
shift 2>/dev/null || true

# 프롬프트: 인자가 있으면 인자 전체, 없으면 stdin
if [ "$#" -gt 0 ]; then
  PROMPT="$*"
else
  PROMPT="$(cat)"
fi

case "$ENGINE" in
  codex)
    if command -v claudex >/dev/null 2>&1; then CLI=claudex
    elif command -v codex >/dev/null 2>&1; then CLI=codex
    else echo "CODEX_NOT_INSTALLED: neither claudex nor codex CLI is installed"; exit 0; fi
    exec "$CLI" -a never exec --sandbox read-only -m gpt-5.5 -c 'model_reasoning_effort="xhigh"' "$PROMPT"
    ;;
  claude)
    command -v claude >/dev/null 2>&1 || { echo "CLAUDE_NOT_INSTALLED: claude CLI is not installed"; exit 0; }
    MODEL="$(deft-model claude 2>/dev/null || echo opus)"
    exec claude -p "$PROMPT" --model "$MODEL" --permission-mode dontAsk --output-format text
    ;;
  gemini)
    command -v gemini >/dev/null 2>&1 || { echo "GEMINI_NOT_INSTALLED: gemini CLI is not installed"; exit 0; }
    exec env GEMINI_POLICY_ALLOW_READONLY=true gemini -p "$PROMPT" -m gemini-3-flash-preview --approval-mode plan -o text 2>/dev/null
    ;;
  ""|-h|--help)
    echo "usage: deft-review <codex|claude|gemini> [prompt]   (prompt 생략 시 stdin)"
    [ -z "$ENGINE" ] && exit 2 || exit 0
    ;;
  *)
    echo "deft-review: unknown engine '$ENGINE' (use codex|claude|gemini)" >&2
    exit 2
    ;;
esac
