#!/bin/bash
# claude-bin-keepalive — Claude Code 버전 바이너리 보존/복원 (teammate spawn 실패 예방)
#
# 문제: teammate spawn 은 Lead 세션과 같은 버전의 바이너리(~/.local/share/claude/versions/<ver>)를
#       실행하는데, 세션이 오래 떠 있는 동안 자동 업데이트가 구버전을 삭제하면
#       "env: .../versions/<ver>: No such file or directory" 로 spawn 이 실패한다.
# 예방: (1) 스킬 실행 시점의 versions/* 를 hardlink 로 보존 (동일 볼륨 — 추가 디스크 0.
#           단, 원본 삭제 후에도 inode 를 잡아두므로 보존 개수만큼 점유 지속 → 정리 정책 必)
#       (2) 팀 spawn 전 호출 시, 원경로가 사라진 보존 버전을 hardlink 로 복원
#       (3) 정리: "실행 중인 세션이 사용하는 버전"은 무조건 보존, 그 외는 최신 KEEP_MAX 개만 유지
#
# 사용: claude-bin-keepalive          # restore → preserve → prune (스킬 Phase 0 표준 호출)
#       claude-bin-keepalive status   # 보존 현황 출력

set -u
VERSIONS_DIR="$HOME/.local/share/claude/versions"
KEEP_DIR="$HOME/.claude/plugin-data/deft/bin-keepalive"
KEEP_MAX=2

[ -d "$VERSIONS_DIR" ] || exit 0   # 버전 관리형 설치가 아니면 해당 없음
mkdir -p "$KEEP_DIR"

# 실행 중인 claude 세션들이 사용하는 버전 (절대 정리 금지 목록)
# 두 형태 합집합 — (a) comm 에 versions/ 풀경로가 보이는 프로세스
#                  (b) comm 이 순수 버전명(예: "2.1.170")인 프로세스 (launcher 경유 세션의 실측 형태)
running_versions() {
  {
    ps -axo comm 2>/dev/null | grep -F "$VERSIONS_DIR/" | sed "s|.*/versions/||"
    ps -axo comm 2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$'
  } | sort -u
}

if [ "${1:-run}" = "status" ]; then
  echo "versions/: $(ls -1 "$VERSIONS_DIR" 2>/dev/null | sort -V | tr '\n' ' ')"
  echo "keepalive: $(ls -1 "$KEEP_DIR" 2>/dev/null | sort -V | tr '\n' ' ')"
  echo "실행 중 세션 버전: $(running_versions | tr '\n' ' ')"
  exit 0
fi

# (1) restore — 보존본이 있는데 원경로가 사라진 버전을 복원 (spawn 경로 생존 보장)
for f in "$KEEP_DIR"/*; do
  [ -f "$f" ] || continue
  v=$(basename "$f")
  if [ ! -e "$VERSIONS_DIR/$v" ]; then
    ln "$f" "$VERSIONS_DIR/$v" 2>/dev/null \
      && echo "INFO: claude $v 바이너리 복원 — 자동 업데이트로 삭제돼 있었음 (teammate spawn 보호)"
  fi
done

# (2) preserve — 현재 versions/* 를 hardlink 보존
for f in "$VERSIONS_DIR"/*; do
  [ -f "$f" ] || continue
  v=$(basename "$f")
  [ -e "$KEEP_DIR/$v" ] || ln "$f" "$KEEP_DIR/$v" 2>/dev/null
done

# (2.5) 이미 늦은 케이스 — 실행 중 세션의 버전이 versions/ 에도 keepalive 에도 없으면
#       원본 복원 불가 (inode 가 이미 unlink, macOS 는 실행 중 바이너리 추출 불가).
#       → 대체 복원: 최신 가용 버전을 그 경로 이름으로 hardlink — teammate spawn 이 최신 바이너리로 실행됨
#         (마이너 버전 불일치 가능성 고지. 실측: 2.1.170 세션 + 2.1.175 대체로 spawn 정상)
LATEST=$(ls -1 "$VERSIONS_DIR" 2>/dev/null | sort -V | tail -1)
HARDFAIL=0   # 대체 복원조차 불가 → 팀 spawn 확정 실패 신호 (호출측 preflight 게이트용)
for v in $(running_versions); do
  if [ ! -e "$VERSIONS_DIR/$v" ] && [ ! -e "$KEEP_DIR/$v" ]; then
    if [ -n "$LATEST" ] && ln "$VERSIONS_DIR/$LATEST" "$VERSIONS_DIR/$v" 2>/dev/null; then
      echo "INFO: claude $v 바이너리를 최신($LATEST)으로 대체 복원 — 원본은 이미 삭제됨. teammate spawn 은 동작하나 부모($v)·자식($LATEST) 버전이 다를 수 있음. 완전 정합을 원하면 해당 세션 재시작(/resume) 권장."
    else
      echo "KEEPALIVE_HARDFAIL: 실행 중인 claude 세션(버전 $v)의 바이너리가 삭제되어 복원 불가 — 그 세션의 팀 spawn 은 반드시 실패합니다. 해당 세션을 재시작(/resume)하세요."
      HARDFAIL=1
    fi
  fi
done

# (3) prune — 실행 중 버전 제외, 최신 KEEP_MAX 개만 유지 (inode 점유 누적 방지)
RUNNING=$(running_versions)
CANDIDATES=$(ls -1 "$KEEP_DIR" 2>/dev/null | sort -V)
KEEPABLE=$(echo "$CANDIDATES" | grep -v -F -x -f <(echo "$RUNNING") 2>/dev/null || echo "$CANDIDATES")
TOTAL=$(echo "$KEEPABLE" | grep -c . || true)
DEL=$((TOTAL - KEEP_MAX))
if [ "$DEL" -gt 0 ]; then
  echo "$KEEPABLE" | head -n "$DEL" | while read -r v; do
    [ -n "$v" ] && rm -f "$KEEP_DIR/$v"
  done
fi
# hard-fail(복원 불가) 시 비정상 종료 → 호출측이 팀 spawn 진입을 차단하는 신호
[ "${HARDFAIL:-0}" = 1 ] && exit 3
exit 0
